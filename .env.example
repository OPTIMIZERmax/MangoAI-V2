# Discord Bot
DISCORD_TOKEN=your_discord_token_here
DISCORD_PREFIX=!

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Redis (Optional, for queue persistence)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Platform Credentials
SPARX_EMAIL=
SPARX_PASSWORD=
EDUCAKE_EMAIL=
EDUCAKE_PASSWORD=
DRFROST_EMAIL=
DRFROST_PASSWORD=
SENECA_EMAIL=
SENECA_PASSWORD=
LANGUAGENUT_EMAIL=
LANGUAGENUT_PASSWORD=

# API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Features
ENABLE_AUTO_SOLVE=true
ENABLE_SESSION_PERSISTENCE=true
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=300000

# Discord Channel IDs
DISCORD_CHANNEL_HOMEWORK_ID=
DISCORD_CHANNEL_SUPPORT_ID=
DISCORD_CHANNEL_PAST_PAPERS_ID=
DISCORD_CHANNEL_SCHEDULE_ID=
